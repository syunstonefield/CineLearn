{
  "manifest_version": 3,
  "name": "CineLearn",
  "version": "1.2.3",
  "description": "ドラマで英語を学ぶ — Netflixなどの字幕単語をクリックして単語帳に保存",

  "icons": {
    "128": "icons/icon-128.png",
    "192": "icons/icon-192.png",
    "512": "icons/icon-512.png"
  },

  "permissions": ["storage"],

  "host_permissions": [
    "https://cinelearn-next.vercel.app/*",
    "https://*.supabase.co/*",
    "https://www.netflix.com/*",
    "https://www.amazon.co.jp/*",
    "https://www.primevideo.com/*",
    "https://www.disneyplus.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["extension/netflix-inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.netflix.com/*",
        "https://www.primevideo.com/*",
        "https://www.amazon.co.jp/gp/video/detail/*",
        "https://www.amazon.co.jp/*/dp/*",
        "https://www.disneyplus.com/*"
      ],
      "js": ["extension/common-words.js", "extension/content.js"],
      "css": ["extension/content.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://cinelearn-next.vercel.app/*"],
      "js": ["extension/bridge.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/icon-192.png"],
      "matches": [
        "https://www.netflix.com/*",
        "https://www.primevideo.com/*",
        "https://www.amazon.co.jp/*",
        "https://www.disneyplus.com/*"
      ]
    }
  ],

  "background": {
    "service_worker": "extension/background.js"
  },

  "options_ui": {
    "page": "extension/options.html",
    "open_in_tab": false
  },

  "action": {
    "default_title": "CineLearnを開く"
  }
}
