{
  "manifest_version": 3,
  "name": "CineLearn",
  "version": "1.0.0",
  "description": "ドラマで英語を学ぶ — Netflixなどの字幕単語をクリックして単語帳に保存",

  "permissions": ["storage", "tabs"],

  "host_permissions": [
    "https://cine-learn.vercel.app/*",
    "https://*.supabase.co/*",
    "https://www.netflix.com/*",
    "https://www.amazon.co.jp/*",
    "https://www.amazon.com/*",
    "https://www.primevideo.com/*",
    "https://www.disneyplus.com/*",
    "https://tv.apple.com/*",
    "https://www.hulu.jp/*",
    "https://video.unext.jp/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.netflix.com/watch/*",
        "https://www.amazon.co.jp/gp/video/*",
        "https://www.amazon.com/gp/video/*",
        "https://www.primevideo.com/detail/*",
        "https://www.disneyplus.com/video/*",
        "https://tv.apple.com/*",
        "https://www.hulu.jp/watch/*",
        "https://video.unext.jp/play/*"
      ],
      "js": ["extension/content.js"],
      "css": ["extension/content.css"],
      "run_at": "document_start"
    }
  ],

  "background": {
    "service_worker": "extension/background.js"
  },

  "action": {
    "default_title": "CineLearnを開く"
  }
}
